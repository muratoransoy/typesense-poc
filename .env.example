# PostgreSQL is the primary database. The Go workers read product changes from it.
POSTGRES_URL=postgres://postgres:postgres@localhost:5432/appdb?sslmode=disable

# Typesense is the search index. The workers write searchable product documents here.
TYPESENSE_HOST=http://localhost:8108
TYPESENSE_API_KEY=xyz
TYPESENSE_COLLECTION=products

# Polling worker checks products.updated_at every 5 seconds.
POLLING_INTERVAL_SECONDS=5

# Outbox worker checks unprocessed search_outbox events every 3 seconds.
OUTBOX_INTERVAL_SECONDS=3
